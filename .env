# ========================================
# AgPay+ 生产环境配置
# ========================================
# 安全提示：
# 1. 请修改所有默认密码为强密码
# 2. 确保数据库连接信息正确
# 3. 使用正式的 SSL 证书
# 4. 定期备份数据
# ========================================

# ========== 环境标识 ==========
ENVIRONMENT=production
COMPOSE_PROJECT_NAME=agpayplus-prod
IMAGE_PREFIX=agpay-prod
IMAGE_TAG=latest

# ========== 域名/IP 配置 ==========
IPORDOMAIN=yourdomain.com

# ========== MySQL 配置 ==========
MYSQL_SERVER_NAME=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=agpayplusdb
MYSQL_USER=root
MYSQL_PASSWORD=your_secure_password_here

# ========== 数据持久化路径 ==========
DATA_PATH_HOST=/var/agpayplus

# ========== SSL 证书路径 ==========
CERT_PATH=/root/.aspnet/https
CERT_PATH_IN_CONTAINER=/https/agpayplusapi.pfx
CERT_PASSWORD=123456

# ========== MQ 配置 ==========
MQ_VENDER=RabbitMQ
MQ_HOSTNAME=rabbitmq
MQ_USERNAME=admin
MQ_PASSWORD=admin
MQ_PORT=5672

# ========== Seq 日志配置 ==========
SEQ_URL=http://seq:80
ENABLE_SEQ=true
SEQ_API_KEY=

# ========== 构建选项 ==========
# 是否构建 cashier（收银台）：true/false
BUILD_CASHIER=false

# ========== Redis 配置 ==========
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== 健康检查配置 ==========
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3

# ========== 备份配置 ==========
BACKUP_ENABLED=true
BACKUP_RETENTION=5
BACKUP_PATH=/var/agpayplus/backup
