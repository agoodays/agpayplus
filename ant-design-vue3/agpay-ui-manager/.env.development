# 应用标题
VITE_APP_TITLE=AgPay管理系统

# API 基础地址
VITE_APP_API_BASE_URL=http://localhost:5817

# Token 存储键名
VITE_APP_TOKEN_NAME=authorization

# 是否开启路由懒加载
VITE_APP_USE_LAZY_ROUTE=true

# 默认路由模式：history 或 hash
VITE_APP_ROUTER_MODE=history

# 开发模式开关（绕过登录验证，显示组件示例菜单）
# 仅在开发环境有效，生产环境会被忽略
VITE_BYPASS_LOGIN=true



