# AgPay 运营平台 - 生产环境配置
# 此文件用于生产环境构建

# 应用标题
VITE_APP_TITLE=AgPay运营平台

# API 基础地址（生产环境）
# 注意：构建时需要修改为实际的生产环境地址
VITE_APP_API_BASE_URL=https://api.yourdomain.com

# Token 存储键名
VITE_APP_TOKEN_NAME=authorization

# 是否开启路由懒加载
VITE_APP_USE_LAZY_ROUTE=true

# 默认路由模式：history 或 hash
VITE_APP_ROUTER_MODE=history

# 生产环境特定配置
VITE_APP_ENABLE_ANALYTICS=true
VITE_APP_ENABLE_ERROR_TRACKING=true
